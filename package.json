{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "dev:inspect": "bun --inspect=0.0.0.0:9229/devtools ./node_modules/vite/bin/vite.js dev --host 0.0.0.0 --port 3000",
    "dev:inspect:wait": "bun --inspect-wait=0.0.0.0:9229/devtools ./node_modules/vite/bin/vite.js dev --host 0.0.0.0 --port 3000",
    "dev:inspect:brk": "bun --inspect-brk=0.0.0.0:9229/devtools ./node_modules/vite/bin/vite.js dev --host 0.0.0.0 --port 3000",
    "debug:arm": "bun scripts/arm-inspector.ts",
    "audio:worker": "bun scripts/audio-worker.ts",
    "cron:register": "bun scripts/register-cron.ts",
    "cron:cleanup:share-codes": "bun scripts/perspectiveShareCleanupCron.ts",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "start": "bun scripts/start.ts",
    "migrate": "bun scripts/migrate.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-pacer": "^0.21.0",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.7",
    "@tanstack/react-start": "1.167.12",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "1.167.8",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  }
}
